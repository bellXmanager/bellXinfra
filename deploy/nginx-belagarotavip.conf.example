# Exemplo Nginx — BellX (fifty2) na mesma VM que o fifty.
# Copiar para sites-available (ex.) e ajustar paths de certificado SSL.
#
# Upstreams internos (PM2 / Node):
#   - bellx-api  -> 127.0.0.1:3050  (bellXback)
#   - bellx-web  -> 127.0.0.1:3002  (next start -p 3002; evita conflito com fifty na 3000)
#
# fifty (existente): tipicamente fifty API em 3000 — nao reutilizar 3000/3050 para outro servico.

upstream bellx_api_upstream {
    server 127.0.0.1:3050;
    keepalive 32;
}

upstream bellx_web_upstream {
    server 127.0.0.1:3002;
    keepalive 32;
}

# --- API: https://api.belagarotavip.com ---
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name api.belagarotavip.com;

    # ssl_certificate     /etc/letsencrypt/live/api.belagarotavip.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/api.belagarotavip.com/privkey.pem;
    # include /etc/letsencrypt/options-ssl-nginx.conf;

    client_max_body_size 25m;

    location / {
        proxy_pass         http://bellx_api_upstream;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   Connection        "";
        proxy_read_timeout  120s;
        proxy_send_timeout  120s;
    }
}

# --- Site Next: https://belagarotavip.com ---
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name belagarotavip.com www.belagarotavip.com;

    # ssl_certificate     /etc/letsencrypt/live/belagarotavip.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/belagarotavip.com/privkey.pem;

    client_max_body_size 25m;

    location / {
        proxy_pass         http://bellx_web_upstream;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        "upgrade";
        proxy_read_timeout  120s;
    }
}


{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "EditBucketCorsAndLocation",
      "Effect": "Allow",
      "Action": [
        "s3:GetBucketCors",
        "s3:PutBucketCors",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::bellx-site-images-sae1",
        "arn:aws:s3:::bellx-site-videos-sae1"
      ]
    },
    {
      "Sid": "ListBucketForDebugging",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::bellx-site-images-sae1",
        "arn:aws:s3:::bellx-site-videos-sae1"
      ]
    },
    {
      "Sid": "ObjectUploadReadDeleteForDev",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:GetObject", "s3:DeleteObject"],
      "Resource": [
        "arn:aws:s3:::bellx-site-images-sae1/*",
        "arn:aws:s3:::bellx-site-videos-sae1/*"
      ]
    }
  ]
}
